#
# terraform.tfvars.example
#
# Copy to terraform.tfvars (which is git-ignored — NEVER commit real values)
# and fill in the account-specific values below.
#
#   cp terraform.tfvars.example terraform.tfvars
#   vim terraform.tfvars
#
# Defaults in variables.tf already cover most fields; only the values
# without defaults MUST be set here.
#

# Required — no default.
aws_account_id = "123456789012"

# Optional — uncomment to override defaults.
# aws_region    = "us-east-1"
# environment   = "prod"
# domain_name   = "eazepay.com"
# app_subdomain = "app"

# Initial image tag to deploy. After first apply, set per-service via CI
# (the CI updates ECS task definitions out-of-band; the `bootstrap` placeholder
# is only used to get the stack to plan/apply cleanly the very first time).
# ecr_image_tag = "bootstrap"

# Sizing overrides — leave defaults until load testing says otherwise.
# rds_instance_class       = "db.t4g.medium"
# rds_allocated_storage_gb = 100
# redis_node_type          = "cache.t4g.micro"
