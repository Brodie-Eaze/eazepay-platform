// EazePay Prisma schema — initial scaffold.
// Domain model in docs/ARCHITECTURE.md §12 will be ported here incrementally.
// Conventions:
//  - all money columns as BigInt (cents).
//  - all timestamps in UTC (Postgres `timestamptz`).
//  - PII columns marked /// PII and target field-level encryption (envelope via KMS) — wired in code, not Prisma.
//  - audit-required tables write through outbox → audit service.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  pending_verification
  active
  locked
  closed
}

enum KycStatus {
  not_started
  in_progress
  approved
  manual_review
  rejected
}

enum PepStatus {
  unknown
  cleared
  match
}

enum LoanCategory {
  auto
  home_improvement
  medical
  retail
  personal
  consolidation
}

enum OriginationChannel {
  consumer_direct
  merchant_link
  merchant_widget
}

enum ApplicationStatus {
  draft
  submitted
  underwriting
  offers_presented
  accepted
  contracted
  funding
  active
  declined
  cancelled
  expired
}

enum OfferStatus {
  presented
  accepted
  expired
  withdrawn
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  /// PII — searchable; deterministic-encrypted at rest in app layer
  email        String?    @unique
  /// PII — searchable; deterministic-encrypted at rest in app layer
  phoneE164    String?    @unique @map("phone_e164")
  /// SECRET — Argon2id; only present for service accounts. Consumer auth via Cognito.
  passwordHash String?    @map("password_hash")
  status       UserStatus @default(pending_verification)
  kycStatus    KycStatus  @default(not_started) @map("kyc_status")
  createdAt    DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6) @map("updated_at")

  sessions        Session[]
  consumerProfile ConsumerProfile?
  applications    Application[]

  @@map("users")
}

// PII vault for consumer KYC data. Stored as a single AES-256-GCM
// envelope-encrypted JSON blob: piiCiphertext is the AAD-bound payload,
// dataKeyCiphertext is the per-record DEK encrypted by the KEK (KMS in
// prod, local-dev KEK from env in development).
//
// Searchable fields like email/phone live on User (deterministic-encrypted
// at the app layer, not here). Anything in this blob is opaque at rest.
model ConsumerProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// PII — AES-256-GCM ciphertext of the full PII JSON blob
  piiCiphertext     Bytes  @map("pii_ciphertext")
  /// PII — 12-byte GCM nonce
  piiNonce          Bytes  @map("pii_nonce")
  /// PII — DEK encrypted with the KEK (KMS or local dev key)
  dataKeyCiphertext Bytes  @map("data_key_ciphertext")
  /// Identifier of the KEK used (KMS key ARN or 'local-dev'); enables key rotation
  kekId             String @map("kek_id")
  /// Schema version of the PII blob payload (allows safe field additions)
  piiSchemaVersion  Int    @default(1) @map("pii_schema_version")

  // Compliance lifecycle (queryable, not PII)
  kycStatus           KycStatus @default(not_started) @map("kyc_status")
  kycProviderRef      String?   @map("kyc_provider_ref")
  kycLastCheckedAt    DateTime? @db.Timestamptz(6) @map("kyc_last_checked_at")
  kycCompletedAt      DateTime? @db.Timestamptz(6) @map("kyc_completed_at")
  pepStatus           PepStatus @default(unknown) @map("pep_status")
  sanctionsCheckedAt  DateTime? @db.Timestamptz(6) @map("sanctions_checked_at")

  // Residency — used for state-rules-matrix routing in orchestration. Not
  // PII on its own; full street address lives encrypted in the blob.
  residentState String? @db.VarChar(2) @map("resident_state")

  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  @@index([kycStatus])
  @@index([residentState])
  @@map("consumer_profiles")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SECRET — SHA-256 hash of refresh token; raw token never stored
  refreshTokenHash String    @map("refresh_token_hash")
  deviceId         String?   @map("device_id")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  createdAt        DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  expiresAt        DateTime  @db.Timestamptz(6) @map("expires_at")
  revokedAt        DateTime? @db.Timestamptz(6) @map("revoked_at")

  @@index([userId, expiresAt])
  @@index([refreshTokenHash])
  @@map("sessions")
}

// Idempotency store backstop — Redis is the hot path; this is the
// durable record so we don't double-charge on Redis flush.
model IdempotencyRecord {
  key          String   @id
  userId       String?  @db.Uuid @map("user_id")
  method       String
  path         String
  requestHash  String   @map("request_hash")
  responseCode Int      @map("response_code")
  responseBody Json     @map("response_body")
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  expiresAt    DateTime @db.Timestamptz(6) @map("expires_at")

  @@index([expiresAt])
  @@map("idempotency_records")
}

// Lending application lifecycle. State transitions are validated by the
// XState machine in services/application; persistence is in this table.
// Money columns are BigInt cents — never floats.
model Application {
  id            String              @id @default(uuid()) @db.Uuid
  userId        String              @db.Uuid @map("user_id")
  user          User                @relation(fields: [userId], references: [id])
  merchantId    String?             @db.Uuid @map("merchant_id")
  channel       OriginationChannel  @default(consumer_direct)
  category      LoanCategory
  /// Money — integer cents (BigInt). Float math is banned by `Cents` brand.
  requestedAmountCents BigInt        @map("requested_amount_cents")
  termMonths    Int                 @map("term_months")
  purposeDetail String?             @map("purpose_detail")
  status        ApplicationStatus   @default(draft)

  // Decision artefacts. Filled in over the application lifecycle by
  // decisioning + orchestration. Snapshot fields, not the full record.
  riskScore           Int?    @map("risk_score")
  affordabilityPasses Boolean? @map("affordability_passes")
  declineReasonCodes  String[] @default([]) @map("decline_reason_codes")
  policyVersion       String? @map("policy_version")

  submittedAt DateTime? @db.Timestamptz(6) @map("submitted_at")
  decisionAt  DateTime? @db.Timestamptz(6) @map("decision_at")
  expiresAt   DateTime? @db.Timestamptz(6) @map("expires_at")
  createdAt   DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")

  offers Offer[]

  @@index([userId, createdAt])
  @@index([merchantId, createdAt])
  @@index([status])
  @@map("applications")
}

model Offer {
  id              String      @id @default(uuid()) @db.Uuid
  applicationId   String      @db.Uuid @map("application_id")
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  lenderProductId String      @db.Uuid @map("lender_product_id")
  /// Lender of record (partner bank or licensed entity) — see ADR-0008
  lenderOfRecord  String      @map("lender_of_record")

  /// Money — integer cents
  amountCents          BigInt @map("amount_cents")
  termMonths           Int    @map("term_months")
  /// APR in basis points (e.g. 1799 = 17.99% APR)
  aprBps               Int    @map("apr_bps")
  /// Reg Z comparison rate in bps; null if not yet computed
  comparisonRateBps    Int?   @map("comparison_rate_bps")
  /// Money — integer cents
  feesCents            BigInt @map("fees_cents")
  /// Money — integer cents
  totalRepayableCents  BigInt @map("total_repayable_cents")

  rank      Int
  status    OfferStatus @default(presented)
  expiresAt DateTime    @db.Timestamptz(6) @map("expires_at")
  createdAt DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt DateTime    @updatedAt @db.Timestamptz(6) @map("updated_at")

  @@index([applicationId, rank])
  @@index([applicationId, status])
  @@map("offers")
}

// Outbox pattern for audit log: every regulated mutation writes a row here
// in the same transaction; a worker drains to the audit service (DynamoDB
// + S3 Object Lock, hash-chained — see docs/ARCHITECTURE.md §17).
model AuditOutbox {
  id          String    @id @default(uuid()) @db.Uuid
  actorType   String    @map("actor_type") // 'user' | 'system' | 'admin' | 'service'
  actorId     String?   @map("actor_id")
  action      String
  targetType  String    @map("target_type")
  targetId    String    @map("target_id")
  before      Json?
  after       Json?
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  occurredAt  DateTime  @default(now()) @db.Timestamptz(6) @map("occurred_at")
  publishedAt DateTime? @db.Timestamptz(6) @map("published_at")

  @@index([publishedAt])
  @@index([targetType, targetId])
  @@map("audit_outbox")
}
