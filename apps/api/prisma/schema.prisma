// EazePay Prisma schema — initial scaffold.
// Domain model in docs/ARCHITECTURE.md §12 will be ported here incrementally.
// Conventions:
//  - all money columns as BigInt (cents).
//  - all timestamps in UTC (Postgres `timestamptz`).
//  - PII columns marked /// PII and target field-level encryption (envelope via KMS) — wired in code, not Prisma.
//  - audit-required tables write through outbox → audit service.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  pending_verification
  active
  locked
  closed
}

/// Internal-staff RBAC. Non-null on a User means this account is an
/// EazePay staff member, not a consumer. The `AdminGuard.isAdmin`
/// boolean is a coarser legacy flag that still gates the existing
/// admin surface; new endpoints should check `platformRole` for the
/// finer-grained Master Command Centre RBAC the partner portal
/// expects.
enum PlatformRole {
  master_admin   // EazePay ops; cross-tenant; can manage other staff
  admin          // Tenant admin within a brand
  underwriter    // Read application detail + decision; cannot manage users
  compliance     // Read/close ComplianceReviews + risk flags
  support        // Read-only customer + application access, ticketing
  read_only      // Reporting / observer
}

enum KycStatus {
  not_started
  in_progress
  approved
  manual_review
  rejected
}

enum PepStatus {
  unknown
  cleared
  match
}

enum LoanCategory {
  auto
  home_improvement
  medical
  retail
  personal
  consolidation
}

enum OriginationChannel {
  consumer_direct
  merchant_link
  merchant_widget
}

enum ApplicationStatus {
  draft
  submitted
  underwriting
  offers_presented
  accepted
  contracted
  funding
  active
  declined
  cancelled
  expired
}

enum OfferStatus {
  presented
  accepted
  expired
  withdrawn
}

enum LenderTier {
  internal // BuzzPay (TrueTopia)
  prime
  near_prime
  bnpl
  subprime
}

/// Credit-tier classification returned by the soft-pull provider
/// (Highsale today; pluggable). Determines which lender pool the
/// orchestration engine evaluates and which offer screen the consumer
/// sees.
enum CreditTier {
  prime_plus
  prime
  near_prime
  sub_prime
  no_match
}

/// A wholesale lender marketplace that exposes many lenders behind one
/// integration (e.g. engine.tech). Different from a direct adapter
/// because the marketplace can add / remove lenders without our
/// engineering team touching code.
enum MarketplaceProvider {
  engine_tech
  in_house
  affiliate_network
  manual
}

enum MarketplaceStatus {
  active
  paused
  disconnected
}

/// Branded sub-products of the EazePay platform. Each brand is a
/// distinct consumer-facing surface (logo + landing + apply variant)
/// that routes to the same orchestration engine but with a tier mix
/// optimised for that vertical. A LenderProduct carries one brand;
/// a Merchant signs up under one brand at onboarding.
enum ProductBrand {
  medpay    // medical, dental, vet, vision, fertility
  tradepay  // home improvement, solar, roof, HVAC, contractor
  coachpay  // coaching, certifications, professional services
  direct    // EazePay direct consumer (any purpose)
}

enum LenderConnectionStatus {
  draft           // created in admin, no credentials yet
  awaiting_creds  // creds requested, waiting on partner
  testing         // creds present, running sandbox handshake
  sandbox_active  // sandbox traffic only
  live            // routing live applications
  paused          // ops-suspended; credentials retained
  revoked         // credentials wiped; cannot re-enable without re-issue
}

enum LenderConnectionEnv {
  sandbox
  live
}

enum LenderHealthcheckOutcome {
  ok
  timeout
  auth_failure
  schema_mismatch
  http_error
  network_error
}

/// Lifecycle of a Highsale soft-pull snapshot. Promoted from
/// stringly-typed to an enum because orchestration branches on it
/// (`scored` gates offer surfacing, `expired` triggers re-pull,
/// `failed` triggers the manual-review fallback).
enum HighsaleSnapshotStatus {
  pending
  scored
  expired
  failed
}

enum LenderRouteOutcome {
  eligible
  ineligible
  approved
  declined
  error
  timeout
}

enum LoanStatus {
