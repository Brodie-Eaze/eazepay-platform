NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Postgres (Aurora in prod). Local dev: docker compose
DATABASE_URL=postgresql://eazepay:eazepay@localhost:5432/eazepay?schema=public
REDIS_URL=redis://localhost:6379

# Auth — local for dev (Argon2id over Postgres). Production: cognito.
AUTH_PROVIDER=local
JWT_ISSUER=https://auth.eazepay.local
JWT_AUDIENCE=eazepay-api
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=please-replace-with-32-bytes-of-randomness-via-openssl-rand-hex-32
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# Encryption — local KEK for dev. Production: kms.
# Generate: openssl rand -hex 32
KEY_MANAGER=local
LOCAL_KEK_HEX=please-replace-with-64-hex-chars-from-openssl-rand-hex-32-aaaaaaa

# KYC — mock for dev. Production: alloy or persona.
KYC_PROVIDER=mock

# E-sign — mock auto-signs synchronously in dev. Production: docusign / dropbox_sign.
ESIGN_PROVIDER=mock

# KYB — mock for dev. Production: middesk or alloy.
KYB_PROVIDER=mock

# Payment rail — mock for dev. Production: modern_treasury / stripe / partner_bank.
PAYMENT_PROVIDER=mock

# Bank-account linking — mock for dev. Production: plaid / mx / finicity.
BANK_ACCOUNT_PROVIDER=mock

# When true, THIS process runs the daily repayment collection cron.
# In a multi-replica deploy, only ONE replica should set this to true.
COLLECTION_CRON_ENABLED=true

# OpenTelemetry
OTEL_SERVICE_NAME=eazepay-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp

# CORS — comma separated; tighten for prod via Terraform output
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003
