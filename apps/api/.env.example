# =====================================================================
# EazePay API (@eazepay/api) — environment template
# =====================================================================
# Copy to .env.local, then run `pnpm run dev` from the repo root.
# Every value below is parsed + validated by apps/api/src/config/env.ts
# at boot; the process refuses to start on a mis-configured prod env.
# =====================================================================

# === Core ===
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# === Database ===
# Postgres (Aurora in prod). Local dev: docker compose up postgres.
DATABASE_URL=postgresql://eazepay:eazepay@localhost:5432/eazepay?schema=public
REDIS_URL=redis://localhost:6379

# === Auth & tokens ===
# `local` = Argon2id over Postgres for dev. Production: cognito.
AUTH_PROVIDER=local
JWT_ISSUER=https://auth.eazepay.local
JWT_AUDIENCE=eazepay-api
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=please-replace-with-32-bytes-of-randomness-via-openssl-rand-hex-32
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# === Encryption (KMS) ===
# `local` = LocalKeyManager for dev. Production: kms.
# Generate KEK with: openssl rand -hex 32
KEY_MANAGER=local
LOCAL_KEK_HEX=please-replace-with-64-hex-chars-from-openssl-rand-hex-32-aaaaaaa

# === Provider selection (all mock in dev) ===
# KYC — mock for dev. Production: alloy or persona.
KYC_PROVIDER=mock
# E-sign — mock auto-signs synchronously in dev. Production: docusign / dropbox_sign.
ESIGN_PROVIDER=mock
# KYB — mock for dev. Production: middesk or alloy.
KYB_PROVIDER=mock
# Payment rail — mock for dev. Production: modern_treasury / stripe / partner_bank.
PAYMENT_PROVIDER=mock
# Bank-account linking — mock for dev. Production: plaid / mx / finicity.
BANK_ACCOUNT_PROVIDER=mock
# Risk providers — mock for dev.
# Device: sift / castle / seon / plaid_signal
# Identity: emailage / telesign / ekata
DEVICE_RISK_PROVIDER=mock
IDENTITY_RISK_PROVIDER=mock

# === Object storage ===
# `local-fs` is dev only. Production: s3.
OBJECT_STORAGE=local-fs
COMPLIANCE_DOC_BUCKET=eazepay-compliance-docs-dev
LOCAL_FS_STORAGE_ROOT=./tmp/object-storage
LOCAL_FS_STORAGE_SIGNING_SECRET=dev-only-replace-me
LOCAL_FS_STORAGE_PUBLIC_URL=http://localhost:3000/v1/dev-storage

# === Cron leader election (READ before scaling beyond 1 replica) ===
# CRON_LEADER is the single umbrella switch for ALL background crons:
#   1. outbound webhook dispatcher (every minute)
#   2. audit-outbox drain          (every minute)
#   3. daily repayment collection  (08:00 UTC)
#
# In a multi-replica deploy (Railway / k8s) you MUST set CRON_LEADER=true
# on exactly ONE replica and CRON_LEADER=false on every other replica.
# When false, every cron no-ops — HTTP still serves normally.
#
# Default false so a fresh multi-replica deploy is safe. Local dev: true.
CRON_LEADER=true

# Per-cron kill-switches. Both these AND CRON_LEADER must be true for
# the cron to fire. Flip one off during incidents without taking the
# whole leader replica down.
COLLECTION_CRON_ENABLED=true
WEBHOOK_DISPATCHER_ENABLED=true
AUDIT_DRAIN_ENABLED=true

# === Audit sink ===
# local-fs (dev) or dynamodb (prod).
AUDIT_SINK=local-fs
AUDIT_LOCAL_FS_ROOT=./tmp/audit-sink

# === Observability ===
OTEL_SERVICE_NAME=eazepay-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp

# === Security: CORS ===
# `CORS_ORIGINS` — dev-friendly alias (comma-separated). Defaults wired
# for the four local apps. Backwards-compat with existing dev configs.
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# `CORS_ALLOWED_ORIGINS` — canonical prod surface (SEC-047). REQUIRED in
# production; superRefine() refuses boot if empty. Example for prod:
#   CORS_ALLOWED_ORIGINS=https://app.eazepay.com,https://partners.eazepay.com
CORS_ALLOWED_ORIGINS=

# `CORS_ORIGIN_PATTERNS` — regex allowlist for dynamic origins (e.g.
# Lovable preview URLs). Defaults wired for non-prod only; prod refuses
# the default Lovable wildcard unless an operator explicitly re-supplies.
# CORS_ORIGIN_PATTERNS=^https://.*\.lovable\.app$,^https://.*\.lovableproject\.com$

# === Security: webhook receivers ===
# Highsale (post-application) HMAC shared secret. Required in non-dev;
# receiver refuses to serve requests when unset. SEC-034: HMAC input is
# `<x-eazepay-timestamp>.<rawBody>` with a ±5min replay window.
HIGHSALE_WEBHOOK_SECRET=please-replace-with-min-16-char-secret

# SEC-034 — enforce timestamp-based replay window on inbound webhooks.
# Default true. Flip to `false` only during a short partner rollover
# window; never leave disabled long-term.
WEBHOOK_REPLAY_WINDOW_ENFORCED=true

# eSign provider webhooks — per-provider HMAC secret. The provider
# slug appears in the route (`/v1/webhooks/esign/:provider`) and the
# secret is looked up via `ESIGN_WEBHOOK_SECRET_${PROVIDER}`.
# Example for DocuSign:
# ESIGN_WEBHOOK_SECRET_DOCUSIGN=please-replace-with-min-16-char-secret

# === Security: Swagger / API docs (SEC-046) ===
# Production: Swagger never mounts.
# Development: open, credentials ignored.
# Staging: BOTH fields required-or-no-Swagger.
SWAGGER_DOCS_USER=
SWAGGER_DOCS_PASS=

# === Lender adapters ===
# US Bank (personal loans, US market). Live values from the partner
# portal. Inbound webhooks are HMAC-SHA256 signed.
US_BANK_BASE_URL=https://api.sandbox.usbank.com
US_BANK_API_KEY=
US_BANK_WEBHOOK_SECRET=

# Engine.Tech (OAuth2 client-credentials, AU + US market). Tokens are
# fetched from `${ENGINE_TECH_BASE_URL}/oauth/token` and cached.
ENGINE_TECH_BASE_URL=https://api.sandbox.engine.tech
ENGINE_TECH_CLIENT_ID=
ENGINE_TECH_CLIENT_SECRET=
ENGINE_TECH_WEBHOOK_SECRET=

# Queen Street (AU lender, bearer token + Ed25519 webhook signing).
QUEEN_STREET_BASE_URL=https://api.sandbox.queenstreet.com.au
QUEEN_STREET_API_TOKEN=
QUEEN_STREET_WEBHOOK_SECRET=
