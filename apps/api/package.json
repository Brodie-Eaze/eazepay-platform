{
  "name": "@eazepay/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "EazePay public API + BFF (NestJS).",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings=0",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@eazepay/service-admin": "workspace:*",
    "@eazepay/service-application": "workspace:*",
    "@eazepay/service-audit": "workspace:*",
    "@eazepay/service-auth": "workspace:*",
    "@eazepay/service-compliance-doc": "workspace:*",
    "@eazepay/service-lender": "workspace:*",
    "@eazepay/service-merchant": "workspace:*",
    "@eazepay/service-notification": "workspace:*",
    "@eazepay/service-orchestration": "workspace:*",
    "@eazepay/service-payment": "workspace:*",
    "@eazepay/service-risk": "workspace:*",
    "@eazepay/service-user": "workspace:*",
    "@eazepay/service-webhook": "workspace:*",
    "@eazepay/shared-types": "workspace:*",
    "@eazepay/shared-utils": "workspace:*",
    "@fastify/helmet": "^11.1.0",
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/throttler": "^6.2.0",
    "@nest-lab/throttler-storage-redis": "^1.1.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "nestjs-pino": "^4.1.0",
    "nestjs-zod": "^4.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.33",
    "@types/node": "^25.8.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
