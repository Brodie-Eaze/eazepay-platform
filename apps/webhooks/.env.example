# webhooks env template — copy to .env

# Postgres — shared with apps/api.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eazepay

# JWT signing secret. Must be at least 32 characters. Used by the
# embedded AuthModule for any partner-issued service tokens that the
# webhook receiver needs to verify.
JWT_ACCESS_SECRET=dev-secret-replace-me-32-bytes-aaaaaaa

# Runtime + logging.
NODE_ENV=development
LOG_LEVEL=info

# HTTP port. Defaults to 3010.
PORT=3010
