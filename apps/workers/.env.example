# workers env template — copy to .env

# Postgres — shared with apps/api.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eazepay

# Runtime + logging.
NODE_ENV=development
LOG_LEVEL=info

# Audit sink. `local-fs` writes day-partitioned JSON files locally
# (great for diffing during dev). `dynamodb` is the prod target.
AUDIT_SINK=local-fs
AUDIT_LOCAL_FS_ROOT=./tmp/audit-sink

# Note: in this process, the collection cron, webhook dispatcher,
# and audit drain are all hard-enabled in workers.module.ts. The
# matching *_ENABLED flags on @eazepay/api should be `false` in prod
# so each cron only fires once per tick.
