{
  "name": "@eazepay/workers",
  "version": "0.0.0",
  "private": true,
  "description": "Distributed cron + queue workers — replaces in-process schedulers in production.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
