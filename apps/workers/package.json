    "@eazepay/service-webhook": "workspace:*",
    "@eazepay/shared-utils": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@prisma/client": "^5.22.0",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
