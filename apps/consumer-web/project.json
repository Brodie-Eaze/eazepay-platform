{
  "name": "consumer-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/consumer-web/app",
  "projectType": "application",
  "tags": ["scope:app", "platform:web"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @eazepay/consumer-web build" }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @eazepay/consumer-web dev" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @eazepay/consumer-web typecheck" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "pnpm --filter @eazepay/consumer-web lint" }
    }
  }
}
