# partner-portal env template — copy to .env.local
#
# The demo runs without any of these set — the landing pages, lender
# hub, and operator UI render with mock data. Set them when wiring
# the BFF round-trip to a running @eazepay/api.

# Base URL of the EazePay API (@eazepay/api).
# In dev: http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# BFF root used by @eazepay/api-client when distinct from
# NEXT_PUBLIC_API_URL. In most setups, leave equal to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_BFF_ROOT=http://localhost:3000

# Railway injects PORT automatically in production — do not set here.
# NODE_ENV / NEXT_TELEMETRY_DISABLED are set by the Dockerfile.
