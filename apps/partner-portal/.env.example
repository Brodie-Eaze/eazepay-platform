# =====================================================================
# partner-portal env template — copy to .env.local
# =====================================================================
# In dev, the demo runs with sensible defaults — landing pages, lender
# hub, and operator UI render with mock data. The cookie secrets fall
# back to a deterministic dev placeholder so local dev + CI work without
# real values.
#
# In production (NODE_ENV=production), `lib/env.ts` runs at module-load
# time and refuses to start the process unless every REQUIRED secret
# below is set with a value of correct length. A failed boot is the
# safe outcome — a half-configured deploy that 500s on first request
# is not.
#
# Generate any secret with:   openssl rand -hex 32
# =====================================================================

# === Auth: cookie signing secrets (REQUIRED in production) ===
# HMAC-SHA256 keys for the two signed-session cookies. Must be ≥ 32 chars.
# Split into separate secrets so one can be rotated without invalidating
# the other (rotating the account secret signs everyone out of real
# accounts while leaving demo sessions intact, and vice versa).
#
# Backward-compat: if ACCOUNT_COOKIE_SECRET is unset, the account-cookie
# module falls back to DEMO_COOKIE_SECRET — but you must set both
# explicitly before any real consumer ships.
DEMO_COOKIE_SECRET=replace-me-with-openssl-rand-hex-32
ACCOUNT_COOKIE_SECRET=replace-me-with-a-different-openssl-rand-hex-32

# === API wiring ===
# Base URL of the EazePay API (@eazepay/api). In dev: http://localhost:3000.
NEXT_PUBLIC_API_URL=http://localhost:3000

# BFF root used by @eazepay/api-client when distinct from the public URL.
# Most setups leave this equal to NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_BFF_ROOT=http://localhost:3000

# Public origin used for absolute URLs in email templates and CSRF checks.
# Should match the URL users see in the browser (no trailing slash).
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3004

# Optimistic BFF mode — when `true`, /api/auth/login + /api/auth/session
# return a synthetic actor when the upstream API is unreachable. Use only
# for local + preview deploys; never in production.
ALLOW_OPTIMISTIC_BFF=true

# === Demo mode ===
# Server-side gate for the demo magic-link endpoint and middleware
# bypass. The sign-in page only renders the demo tiles when the
# NEXT_PUBLIC_ mirror is set. Both must be `true` to enable demo.
#
# Template default is `false` (SEC-EZ-002): the example must never ship a
# demo escape hatch in the ON position. Set both to `true` for local dev
# AND for the canonical preview/demo deploy (where apps/api is NOT running
# and the demo TILES are the only way in).
#
# Safe to enable even on a NODE_ENV=production preview: the seed-email
# fallback inside /api/auth/login is HARD-disabled when NODE_ENV=production
# (isDemoFallbackAllowed() returns false), so this flag cannot mint a login
# session in prod. It only governs the explicit, origin- + master-gated
# demo TILES at /api/auth/demo. A REAL production deploy serving real auth
# should leave both `false`.
DEMO_MODE_ENABLED=false
NEXT_PUBLIC_DEMO_MODE_ENABLED=false

# Whether the `master` operator preset can be activated via the demo
# tile. The master preset confers cross-tenant admin visibility, so
# this defaults to `false` in production deploys regardless of
# DEMO_MODE_ENABLED. Set explicitly to `true` only in staging where
# operators need cross-tenant access via the demo flow.
DEMO_MASTER_ENABLED=false

# === Security: webhook receivers (SEC-003) ===
# In production (or when REQUIRE_HMAC=true), inbound lender webhooks
# with `verifiedSignature: 'skipped'` are refused. In dev the skip path
# is permitted so adapters can stub locally without secrets.
REQUIRE_HMAC=false

# === Security: integration webhook signing (SEC-002 — REQUIRED in prod) ===
# HMAC-SHA256 secrets for the MiCamp + HighSale/Milly inbound webhooks.
# Each ≥ 32 chars. Without these set, `verifyWebhookSignature()` in
# lib/micamp/client.ts and `verifyHighsaleSignature()` in
# lib/highsale/client.ts cannot fail-closed. In production the modules
# refuse to load and `assertProdEnv()` refuses to boot the worker.
#
# In non-production these may be unset for unit tests; webhook routes
# will return 401 (default-deny). To explicitly opt in to accepting
# unsigned webhooks for local development, set the matching
# *_WEBHOOK_INSECURE_ALLOW flag below — those flags are NEVER safe in
# prod and `verify*` still returns `{ valid: false }` when used.
MICAMP_WEBHOOK_SECRET=replace-me-with-openssl-rand-hex-32
HIGHSALE_WEBHOOK_SECRET=replace-me-with-openssl-rand-hex-32
MICAMP_WEBHOOK_INSECURE_ALLOW=false
HIGHSALE_WEBHOOK_INSECURE_ALLOW=false

# SEC-EZ-001 — inbound lender webhook + quote-callback HMAC secret.
# Used by lib/api-v1/shared.ts `verifySignature()` for the routes
# /api/v1/webhooks/lenders/[lender] and /api/v1/lenders/[lenderId]/quote.
# Resolution order, per lender id: LENDER_<SLUG>_WEBHOOK_SECRET (per-lender
# override, e.g. LENDER_LP_BUZZPAY_PRIME_WEBHOOK_SECRET) then this shared
# fallback. ≥ 32 chars. Unset in PRODUCTION → verifier fails closed (401),
# never accepts an unsigned/forged event. Unset in non-prod → a fixed
# dev placeholder is used so local demo flows work (NEVER reachable in
# prod). The old committed `demo_shared_secret_replace_in_prod` constant
# has been removed; signatures made with it are rejected everywhere.
LENDER_WEBHOOK_SECRET=replace-me-with-openssl-rand-hex-32

# === Email (Resend) — optional, used by invite + invoice flows ===
# Without these, the email helpers log the would-be send instead of
# transmitting. Set to a real Resend API key + matching from-domain
# verified in Resend to actually deliver.
RESEND_API_KEY=
# When `true`, treats every recipient as a sandbox address (Resend's
# test mode). Use in staging + preview deploys.
RESEND_TEST_MODE=true

# === Payments (Stripe) — optional, used by /api/billing/stripe/* ===
# When unset, the Stripe setup-fee endpoint returns a `{ stub: true }`
# payload that bypasses to the brand onboarding page (no charge). When
# set, the endpoint mints a real Stripe Checkout session. Lives outside
# the cookie-secret guard because the platform can run end-to-end demo
# flows without it; the moment a real customer is invited, it must be
# set.
STRIPE_SECRET_KEY=

# === Database (Postgres) — optional, gated by lib/db/hasDb() ===
# Connection string for the applications data layer (per ADR-0020).
# When unset, application read/write APIs return 503 db_unavailable and
# dashboards fall back to the localStorage substrate. Required once
# real consumer applications are flowing.
#
# Railway autoinjects this when the Postgres plugin is attached. Local
# dev: `postgresql://eazepay:eazepay@localhost:5432/eazepay_dev`.
DATABASE_URL=

# === Edge PII encryption at rest (PRIV-002, SOC 2 CC6.1 / GLBA) ===
# The applications table encrypts consumer first/last/email/phone at rest
# with the SAME envelope scheme the backend apps/api vault uses. Reuse
# the same KEK material across both so there is one key to rotate.
#
# KEY_MANAGER selects the envelope key manager:
#   local     (default) — KEK from LOCAL_KEK_HEX. Dev + current prod.
#   mock-kms             — MockKmsKeyManager (rewrap-cutover parity).
# AWS KMS drops in here once the CMK ARN is provisioned.
KEY_MANAGER=local
# 32-byte (64 hex chars) KEK for KEY_MANAGER=local. REQUIRED for any
# application read/write once DATABASE_URL is set. Generate via:
#   openssl rand -hex 32
# This is the SAME value as apps/api's LOCAL_KEK_HEX.
LOCAL_KEK_HEX=
# Separate HMAC key for the deterministic email blind index. MUST DIFFER
# from LOCAL_KEK_HEX (never reuse a confidentiality key as a MAC key).
# Generate via: openssl rand -hex 32
EDGE_PII_BLIND_INDEX_KEY=

# === Runtime hints ===
# Railway injects PORT automatically in production — do not set here.
# NODE_ENV / NEXT_TELEMETRY_DISABLED are set by the Dockerfile.
