{
  "name": "service-application",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/application/src",
  "projectType": "library",
  "tags": ["scope:service", "domain:application", "regulated:true"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p services/application/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint services/application/src --max-warnings=0"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --root services/application"
      }
    }
  }
}
