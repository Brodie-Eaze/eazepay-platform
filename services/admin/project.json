{
  "name": "service-admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/admin/src",
  "projectType": "library",
  "tags": ["scope:service", "domain:admin", "regulated:true"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p services/admin/tsconfig.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint services/admin/src --max-warnings=0" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --root services/admin" }
    }
  }
}
