{
  "name": "service-lender",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/lender/src",
  "projectType": "library",
  "tags": ["scope:service", "domain:lender", "regulated:true"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p services/lender/tsconfig.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint services/lender/src --max-warnings=0" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --root services/lender" }
    }
  }
}
