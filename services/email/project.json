{
  "name": "service-email",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/email/src",
  "projectType": "library",
  "tags": ["scope:service", "domain:email"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p services/email/tsconfig.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint services/email/src --max-warnings=0" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --root services/email" }
    }
  }
}
