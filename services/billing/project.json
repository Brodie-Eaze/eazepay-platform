{
  "name": "service-billing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/billing/src",
  "projectType": "library",
  "tags": ["scope:service", "domain:billing", "regulated:true"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p services/billing/tsconfig.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint services/billing/src --max-warnings=0" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --root services/billing" }
    }
  }
}
