{
  "name": "service-user",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/user/src",
  "projectType": "library",
  "tags": ["scope:service", "domain:user", "regulated:true"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p services/user/tsconfig.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint services/user/src --max-warnings=0"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --root services/user"
      }
    }
  }
}
