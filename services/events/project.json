{
  "name": "service-events",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/events/src",
  "projectType": "library",
  "tags": ["scope:service", "domain:events", "regulated:true"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p services/events/tsconfig.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint services/events/src --max-warnings=0" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --root services/events" }
    }
  }
}
