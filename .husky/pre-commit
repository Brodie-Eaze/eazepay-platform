#!/usr/bin/env sh
# Pre-commit hook for the EazePay monorepo.
#
# Runs lint-staged on every commit so any file touched by the commit
# gets Prettier auto-formatted before it enters history. The lint-staged
# config lives in root package.json under "lint-staged".
#
# Side-effect-free: lint-staged stashes unrelated changes, runs the
# formatter, re-stages the formatted files, then restores the stash.
# A commit fails only when Prettier produces an unrecoverable error
# (e.g. genuine syntax error) — which is what we want.
#
# When ESLint is fully wired across the workspace, add:
#   pnpm exec lint-staged   # already covers prettier
#   pnpm exec nx affected -t typecheck --base=HEAD~1 --head=HEAD --parallel=3
# to enforce typecheck on the affected packages too.
pnpm exec lint-staged
